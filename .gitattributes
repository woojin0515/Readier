###############################################################################
# Default: auto-detect text files and normalize line endings on commit.
# Working tree gets native line endings; repo stores LF.
###############################################################################
* text=auto eol=lf

###############################################################################
# C# / .NET MAUI source and project files
###############################################################################
*.cs            text eol=lf diff=csharp
*.csproj        text eol=lf
*.props         text eol=lf
*.targets       text eol=lf
*.sln           text eol=crlf
*.xaml          text eol=lf
*.xml           text eol=lf
*.config        text eol=lf
*.json          text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.editorconfig  text eol=lf
*.gitignore     text eol=lf
*.gitattributes text eol=lf

###############################################################################
# Platform scripts — must keep their native endings
###############################################################################
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf
*.sh            text eol=lf

###############################################################################
# Binary assets — never normalize, never diff as text
###############################################################################
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
*.zip       binary
*.7z        binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.snk       binary
*.pfx       binary
*.p12       binary
*.keystore  binary
*.jks       binary
*.appx      binary
*.msix      binary
*.msixbundle binary

# SVG: text but always LF
*.svg       text eol=lf

###############################################################################
# GitHub language stats: ignore generated/build folders
###############################################################################
bin/        linguist-generated=true
obj/        linguist-generated=true

<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Readier"
             x:Class="Readier.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Readier design tokens -->
            <Color x:Key="ReadierAccent">#5B7CFA</Color>
            <Color x:Key="ReadierAccentDim">#3F5AB5</Color>
            <Color x:Key="ReadierDanger">#EF4444</Color>

            <Color x:Key="ReadierBgLight">#FAFAFA</Color>
            <Color x:Key="ReadierBgDark">#0F1115</Color>

            <Color x:Key="ReadierSurfaceLight">#FFFFFF</Color>
            <Color x:Key="ReadierSurfaceDark">#1B1E26</Color>

            <Color x:Key="ReadierDividerLight">#E5E7EB</Color>
            <Color x:Key="ReadierDividerDark">#2A2E38</Color>

            <Color x:Key="ReadierTextLight">#0F1115</Color>
            <Color x:Key="ReadierTextDark">#E5E7EB</Color>

            <Color x:Key="ReadierTextSubtleLight">#6B7280</Color>
            <Color x:Key="ReadierTextSubtleDark">#9DA3AE</Color>

            <!-- Common control style: bordered, rounded entry -->
            <Style x:Key="FormEntry" TargetType="Entry">
                <Setter Property="HeightRequest" Value="44" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="BackgroundColor" Value="Transparent" />
            </Style>

            <Style x:Key="SectionHeader" TargetType="Label">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                <Setter Property="Margin" Value="4,8,4,4" />
            </Style>

            <Style x:Key="SurfaceCard" TargetType="Border">
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeShape" Value="RoundRectangle 14" />
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource ReadierSurfaceLight}, Dark={StaticResource ReadierSurfaceDark}}" />
                <Setter Property="Padding" Value="16,14" />
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ReadierAccent}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>

            <Style x:Key="SecondaryButton" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                <Setter Property="HeightRequest" Value="50" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource ReadierDividerLight}, Dark={StaticResource ReadierDividerDark}}" />
                <Setter Property="BorderWidth" Value="1" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>

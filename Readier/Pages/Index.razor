@page "/"
@page "/schedules"
@implements IDisposable
@inject ScheduleListViewModel ViewModel
@inject IUserPreferencesService Preferences
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Readier.Helpers

<PageTitle>일정</PageTitle>

<div class="page-stack">
    <section class="card home-welcome-card">
        <div class="home-welcome-eyebrow">오늘도 여유 있게</div>
        <h1 class="home-welcome-title">@GreetingMessage</h1>
        <p class="muted home-welcome-copy">@(PersonalizedAgendaTitle)에서 준비 시작/출발 시간을 바로 확인해요.</p>
        @if (_needsSurveyOnboarding)
        {
            <div class="home-onboarding-row">
                <div class="home-onboarding-copy">회원가입 루틴 분석을 아직 완료하지 않았어요. 1분 설문으로 기본 준비 시간을 더 정확하게 맞출 수 있어요.</div>
                <a class="button-primary" href="/insights">분석 조사 시작</a>
            </div>
        }
    </section>

    <section class="card controls-card">
        <div class="segmented">
            <button type="button" class="segment @(ViewModel.IsAgendaMode ? "active" : string.Empty)" @onclick="ShowAgendaAsync">오늘 아젠다</button>
            <button type="button" class="segment @(!ViewModel.IsAgendaMode ? "active" : string.Empty)" @onclick="ShowCalendarAsync">캘린더 탐색</button>
        </div>
    </section>

    @if (ViewModel.IsAgendaMode && ViewModel.HasNextUpcoming)
    {
        <section class="card next-summary-card">
            <div class="muted">다음 일정</div>
            <div class="next-summary-title">@ViewModel.NextUpcomingItem!.Title</div>
            @if (ViewModel.NextUpcomingItem!.HasDestination)
            {
                <div class="next-summary-meta">
                    <span class="icon">📍</span>
                    <span>@ViewModel.NextUpcomingItem!.DestinationLabel</span>
                </div>
            }
            <div class="next-summary-meta">
                <span class="icon">🕐</span>
                <span>@ViewModel.NextUpcomingItem!.StartTime.ToString("HH:mm")</span>
            </div>
        </section>
    }

    @if (ViewModel.IsAgendaMode)
    {
        <section class="section-header">
            <div>
                <h1>@PersonalizedAgendaTitle</h1>
                <p class="muted">준비 시작/출발 시각을 확인하고 일정을 준비하세요.</p>
            </div>
            <div class="agenda-quick-nav" role="group" aria-label="아젠다 날짜 선택">
                <button type="button" class="button-tonal @(!ViewModel.IsThisWeekMode && ViewModel.SelectedDate.Date == AppClock.Today ? "active" : string.Empty)" @onclick="GoToTodayAsync">오늘</button>
                <button type="button" class="button-tonal @(!ViewModel.IsThisWeekMode && ViewModel.SelectedDate.Date == AppClock.Today.AddDays(1) ? "active" : string.Empty)" @onclick="GoToTomorrowAsync">내일</button>
                <button type="button" class="button-tonal @(ViewModel.IsThisWeekMode ? "active" : string.Empty)" @onclick="GoToThisWeekAsync">이번주</button>
            </div>
        </section>

        @if (ViewModel.IsThisWeekMode)
        {
            <section class="week-chip-row" aria-label="이번주 날짜 선택">
                @foreach (var date in ViewModel.ThisWeekDates)
                {
                    <button type="button"
                        class="week-chip @(date.Date < AppClock.Today ? "past" : string.Empty) @(ViewModel.SelectedDate.Date == date.Date ? "active" : string.Empty)"
                            @onclick="() => SelectThisWeekDateAsync(date)">
                        <span>@date.ToString("ddd")</span>
                        <strong>@date.ToString("M/d")</strong>
                    </button>
                }
            </section>
        }

        @if (ViewModel.VisibleItems.Count == 0)
        {
            <section class="card empty-card">
                <h2>@ViewModel.EmptyAgendaMessage</h2>
                <p class="muted">@(ViewModel.ShowLateOnly ? "예정된 일정을 모두 정시에 준비하고 계세요." : "우측 하단 + 버튼으로 첫 일정을 추가하세요. 준비/출발 시각을 자동 계산해 드려요.")</p>
            </section>
        }
        else
        {
            <div class="stack">
                @foreach (var item in ViewModel.VisibleItems)
                {
                    <article class="card schedule-card @(item.IsLeaveLate ? "late" : string.Empty) @(item.IsPastSchedule ? "past" : string.Empty)" @onclick="() => EditAsync(item)">
                        <div class="time-column">@item.StartTime.ToString("HH:mm")</div>
                        <div class="accent-bar"></div>
                        <div class="schedule-content">
                            <div class="schedule-title">@item.Title</div>
                            @if (item.IsPastSchedule)
                            {
                                <span class="status-pill past">지난 일정</span>
                            }
                            @if (item.HasDestination)
                            {
                                <div class="schedule-subtitle">@item.DestinationLabel</div>
                            }
                            <div class="badge-row">
                                <span class="badge prep">준비 <strong>@item.DisplayStartPrepAt.ToString("HH:mm")</strong></span>
                                <span class="badge leave">출발 <strong>@item.DisplayLeaveAt.ToString("HH:mm")</strong></span>
                            </div>
                            @if (item.IsLeaveLate)
                            {
                                <div class="late-note">⚠️ 이미 늦었어요</div>
                            }
                        </div>
                        <button type="button" class="card-delete" @onclick:stopPropagation="true" @onclick="() => DeleteAsync(item)">삭제</button>
                    </article>
                }
            </div>
        }
    }
    else
    {
        <section class="card calendar-card">
            <div class="calendar-toolbar">
                <button type="button" class="button-tonal icon" @onclick="PreviousMonthAsync">◀</button>
                <h1>@ViewModel.CalendarMonthTitle</h1>
                <button type="button" class="button-tonal icon" @onclick="NextMonthAsync">▶</button>
            </div>

            <div class="weekday-row">
                <span>일</span><span>월</span><span>화</span><span>수</span><span>목</span><span>금</span><span>토</span>
            </div>

            <div class="calendar-grid">
                @foreach (var day in ViewModel.CalendarDays)
                {
                    <button type="button" class="calendar-day @(day.IsCurrentMonth ? string.Empty : "dimmed") @(day.Date < AppClock.Today ? "past" : string.Empty) @(day.IsSelected ? "selected" : string.Empty)" @onclick="() => SelectDateAsync(day.Date)">
                        <span>@day.DayLabel</span>
                        @if (day.HasItems)
                        {
                            <span class="day-dot"></span>
                        }
                    </button>
                }
            </div>
        </section>

        <section class="card">
            <h2>@ViewModel.AgendaTitle</h2>
            @if (ViewModel.VisibleItems.Count == 0)
            {
                <p class="muted">선택한 날짜에 일정이 없어요.</p>
            }
            else
            {
                <div class="mini-list">
                    @foreach (var item in ViewModel.VisibleItems)
                    {
                        <div class="mini-row @(item.IsPastSchedule ? "past" : string.Empty)" @onclick="() => EditAsync(item)">
                            <span>@item.StartTime.ToString("HH:mm")</span>
                            <div class="mini-row-content">
                                <div class="mini-row-title">@item.Title</div>
                                @if (item.IsPastSchedule)
                                {
                                    <span class="status-pill past">지난 일정</span>
                                }
                                @if (item.HasDestination)
                                {
                                    <div class="mini-row-subtitle">@item.DestinationLabel</div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    }

    <button type="button" class="fab" @onclick="AddAsync">+</button>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string? _displayName;
    private bool _needsSurveyOnboarding;
    private CancellationTokenSource? _clockRefreshCts;

    private string GreetingMessage => string.IsNullOrWhiteSpace(_displayName)
        ? "안녕하세요"
        : $"안녕하세요, {_displayName}님";

    private string PersonalizedAgendaTitle => string.IsNullOrWhiteSpace(_displayName)
        ? ViewModel.AgendaTitle
        : $"{_displayName}님의 일정";

    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadCommand.ExecuteAsync(null);
        await LoadUserContextAsync();
        StartClockRefresh();
    }

    private async Task LoadUserContextAsync()
    {
        var authState = AuthenticationStateTask is null
            ? null
            : await AuthenticationStateTask;

        var user = authState?.User;
        var claimName = ResolveClaimName(user);

        var prefs = await Preferences.GetAsync();
        _displayName = string.IsNullOrWhiteSpace(prefs.DisplayName)
            ? claimName
            : prefs.DisplayName;

        _needsSurveyOnboarding = user?.Identity?.IsAuthenticated == true
                                 && prefs.PreparationProfile.Answers.Count == 0;
    }

    private static string? ResolveClaimName(ClaimsPrincipal? user)
    {
        if (user is null || user.Identity?.IsAuthenticated != true)
            return null;

        var candidates = new[]
        {
            user.FindFirst(ClaimTypes.GivenName)?.Value,
            user.FindFirst(ClaimTypes.Name)?.Value,
            user.Identity?.Name,
            user.FindFirst(ClaimTypes.Email)?.Value
        };

        foreach (var candidate in candidates)
        {
            if (!string.IsNullOrWhiteSpace(candidate))
                return candidate.Split('@')[0];
        }

        return null;
    }

    private async Task ShowAgendaAsync()
    {
        ViewModel.ShowAgendaCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ShowCalendarAsync()
    {
        ViewModel.ShowCalendarCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToTodayAsync()
    {
        ViewModel.GoToTodayCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToTomorrowAsync()
    {
        ViewModel.GoToTomorrowCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task GoToThisWeekAsync()
    {
        ViewModel.GoToThisWeekCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectThisWeekDateAsync(DateTime date)
    {
        ViewModel.SelectThisWeekDateCommand.Execute(date);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleLateOnlyAsync()
    {
        ViewModel.ShowLateOnly = !ViewModel.ShowLateOnly;
        ViewModel.ShowAgendaCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task PreviousMonthAsync()
    {
        ViewModel.PreviousMonthCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task NextMonthAsync()
    {
        ViewModel.NextMonthCommand.Execute(null);
        await InvokeAsync(StateHasChanged);
    }

    private async Task SelectDateAsync(DateTime date)
    {
        ViewModel.SelectDateCommand.Execute(date);
        await InvokeAsync(StateHasChanged);
    }

    private async Task AddAsync()
    {
        await ViewModel.AddCommand.ExecuteAsync(null);
    }

    private async Task EditAsync(ScheduleListItemViewModel item)
    {
        await ViewModel.EditCommand.ExecuteAsync(item);
    }

    private async Task DeleteAsync(ScheduleListItemViewModel item)
    {
        await ViewModel.DeleteCommand.ExecuteAsync(item);
        await InvokeAsync(StateHasChanged);
    }

    private void StartClockRefresh()
    {
        _clockRefreshCts?.Cancel();
        _clockRefreshCts = new CancellationTokenSource();
        var token = _clockRefreshCts.Token;

        _ = Task.Run(async () =>
        {
            try
            {
                using var timer = new PeriodicTimer(TimeSpan.FromSeconds(30));
                while (await timer.WaitForNextTickAsync(token))
                {
                    ViewModel.RefreshNowSensitiveState();
                    await InvokeAsync(StateHasChanged);
                }
            }
            catch (OperationCanceledException)
            {
            }
        }, token);
    }

    public void Dispose()
    {
        _clockRefreshCts?.Cancel();
        _clockRefreshCts?.Dispose();
    }
}

@page "/settings"
@inject SettingsViewModel ViewModel

<PageTitle>@ViewModel.Title</PageTitle>

<div class="page-stack">
    <section class="card">
        <h1>프로필</h1>
        <label>
            <span>표시 이름</span>
            <input class="form-input" placeholder="예: 우진" @bind="ViewModel.DisplayName" />
        </label>
        <p class="muted">홈 화면 인사와 일정 제목에 사용됩니다.</p>
    </section>

    <section class="card">
        <h2>알림 설정</h2>
        <label class="switch-row">
            <span>알림 사용</span>
            <input type="checkbox" @bind="ViewModel.NotificationsEnabled" />
        </label>
        <p class="muted">끄면 일정 저장 시 준비/출발 알림이 예약되지 않습니다.</p>
    </section>

    <section class="card">
        <h2>알림 디테일</h2>
        <label>
            <span>출발 전 추가 알림</span>
            <select class="form-input" @bind="ViewModel.LeaveSoonReminderMinutes">
                @foreach (var minute in ViewModel.ReminderMinuteOptions)
                {
                    <option value="@minute">@minute 분</option>
                }
            </select>
        </label>
        <p class="muted-note">0분은 사용 안 함입니다. 5분 이상 설정하면 출발 전에 한 번 더 알려드려요.</p>

        <div class="divider"></div>

        <label>
            <span>기본 미루기</span>
            <select class="form-input" @bind="ViewModel.SnoozePresetMinutes">
                @foreach (var minute in ViewModel.SnoozeMinuteOptions)
                {
                    <option value="@minute">@minute 분</option>
                }
            </select>
        </label>

        <label class="switch-row">
            <span>부담 없는 알림 문구</span>
            <input type="checkbox"
                   class="switch-input"
                   @bind="ViewModel.UseCalmReminderCopy"
                   @bind:after="OnCalmReminderChangedAsync" />
        </label>
        <button type="button" class="button-secondary full mt-12" @onclick="PreviewReminderAsync">이렇게 표시됩니다</button>
        <p class="muted-note">누르면 브라우저 알림으로 실제 미리보기가 뜹니다.</p>

        @if (ViewModel.HasPreviewError)
        {
            <div class="status error">@ViewModel.PreviewMessage</div>
        }
        @if (ViewModel.HasPreviewInfo)
        {
            <div class="status info">@ViewModel.PreviewMessage</div>
        }
    </section>

    <section class="card">
        <h2>iOS 확장 <span class="section-pending">(향후 예정)</span></h2>
        <p class="muted">Live Activities / Dynamic Island 지원은 2차 구현 예정입니다.</p>
    </section>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadAsync();
    }

    private async Task OnCalmReminderChangedAsync()
    {
        await ViewModel.PreviewReminderAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task PreviewReminderAsync()
    {
        await ViewModel.PreviewReminderAsync();
        await InvokeAsync(StateHasChanged);
    }
}

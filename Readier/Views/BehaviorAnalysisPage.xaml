<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Readier.ViewModels"
             x:Class="Readier.Views.BehaviorAnalysisPage"
             x:DataType="vm:BehaviorAnalysisViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="10">

            <!-- Hero summary -->
            <Border Style="{StaticResource SurfaceCard}"
                    BackgroundColor="{StaticResource ReadierAccent}"
                    Padding="20,18">
                <VerticalStackLayout Spacing="6">
                    <Label Text="추정 준비 시간"
                           FontSize="12"
                           TextColor="White"
                           Opacity="0.85" />
                    <Label Text="{Binding EstimatedPrepMinutes, StringFormat='약 {0}분'}"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="평소 루틴에 가장 가까운 항목을 골라 주세요. 응답이 종합되어 평균 준비 시간이 자동 계산됩니다."
                           FontSize="11"
                           TextColor="White"
                           Opacity="0.85"
                           Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

            <!-- Survey questions -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Questions}"
                                 Spacing="8"
                                 Margin="0,6,0,0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:SurveyQuestionViewModel">
                        <Border Style="{StaticResource SurfaceCard}">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding QuestionTitle}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                <Picker ItemsSource="{Binding OptionLabels}"
                                        SelectedIndex="{Binding SelectedIndex}"
                                        FontSize="14"
                                        TextColor="{StaticResource ReadierAccent}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

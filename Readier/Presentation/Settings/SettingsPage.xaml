<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Readier.ViewModels"
             x:Class="Readier.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="6">

            <Label Text="알림" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SurfaceCard}">
                <Grid ColumnDefinitions="*,Auto" Padding="0,4">
                    <Label Grid.Column="0"
                           Text="알림 사용"
                           FontSize="15"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                    <Switch Grid.Column="1"
                            IsToggled="{Binding NotificationsEnabled}"
                            OnColor="{StaticResource ReadierAccent}"
                            VerticalOptions="Center" />
                </Grid>
            </Border>
            <Label Text="끄면 새로 저장하는 일정에 알림이 예약되지 않습니다"
                   FontSize="11"
                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}"
                   Margin="4,2,4,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

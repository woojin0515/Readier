<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Readier.ViewModels"
             x:Class="Readier.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}">

    <ScrollView>
        <VerticalStackLayout Padding="16,12,16,24" Spacing="10">
            <Label Text="알림 설정" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SurfaceCard}" Padding="16,12">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                        <Label Grid.Column="0"
                               Text="알림 사용"
                               FontSize="15"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding NotificationsEnabled}"
                                OnColor="{StaticResource ReadierAccent}"
                                VerticalOptions="Center" />
                    </Grid>
                    <Label Text="끄면 일정 저장 시 준비/출발 알림이 예약되지 않습니다."
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="알림 디테일" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SurfaceCard}" Padding="16,12">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="출발 전 추가 알림"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Picker Grid.Column="1"
                                WidthRequest="130"
                                ItemsSource="{Binding ReminderMinuteOptions}"
                                SelectedItem="{Binding LeaveSoonReminderMinutes}"
                                FontSize="13"
                                TextColor="{StaticResource ReadierAccent}" />
                    </Grid>
                    <Label Text="0분은 사용 안 함입니다. 5분 이상 설정하면 출발 전에 한 번 더 알려드려요."
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />

                    <BoxView HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource ReadierDividerLight}, Dark={StaticResource ReadierDividerDark}}" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="기본 미루기(준비중)"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Picker Grid.Column="1"
                                WidthRequest="130"
                                ItemsSource="{Binding SnoozeMinuteOptions}"
                                SelectedItem="{Binding SnoozePresetMinutes}"
                                FontSize="13"
                                TextColor="{StaticResource ReadierAccent}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="부담 없는 알림 문구 사용"
                               FontSize="14"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding UseCalmReminderCopy}"
                                OnColor="{StaticResource ReadierAccent}" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label Text="iOS 확장(설계 단계)" Style="{StaticResource SectionHeader}" />
            <Border Style="{StaticResource SurfaceCard}" Padding="16,12">
                <Label Text="Live Activities / Dynamic Island는 2차 구현 예정입니다. 1차는 상태 정의와 카피 톤을 우선 고정합니다."
                       FontSize="12"
                       TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

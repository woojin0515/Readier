<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Readier.ViewModels"
             x:Class="Readier.Views.ScheduleListPage"
             x:DataType="vm:ScheduleListViewModel"
             x:Name="page"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Margin="14,10,14,6" Style="{StaticResource SurfaceCard}" Padding="10">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="오늘 아젠다"
                        Style="{StaticResource TonalButton}"
                        Command="{Binding ShowAgendaCommand}" />
                <Button Grid.Column="1"
                        Text="캘린더 탐색"
                        Style="{StaticResource TonalButton}"
                        Command="{Binding ShowCalendarCommand}" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="14,0,14,92">
            <Grid IsVisible="{Binding IsAgendaMode}" RowDefinitions="Auto,*" RowSpacing="8">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="{Binding AgendaTitle}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Label Text="준비 시작/출발 시각을 기준으로 오늘 흐름을 확인하세요"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="오늘"
                            Style="{StaticResource TonalButton}"
                            Command="{Binding GoToTodayCommand}" />
                </Grid>

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding VisibleItems}"
                                SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Border Style="{StaticResource SurfaceCard}" Padding="24,28">
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="10">
                                <Label Text="오늘 일정이 비어 있어요"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                <Label Text="우측 하단 + 버튼으로 첫 일정을 추가하면 준비 시작/출발 시각을 자동 계산해 드려요."
                                       FontSize="13"
                                       HorizontalTextAlignment="Center"
                                       TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:ScheduleListItemViewModel">
                            <SwipeView Margin="0,4">
                                <SwipeView.RightItems>
                                    <SwipeItems Mode="Reveal">
                                        <SwipeItem Text="삭제"
                                                   BackgroundColor="{StaticResource ReadierDanger}"
                                                   Command="{Binding Source={x:Reference page}, Path=ViewModel.DeleteCommand}"
                                                   CommandParameter="{Binding .}" />
                                    </SwipeItems>
                                </SwipeView.RightItems>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference page}, Path=ViewModel.EditCommand}"
                                                              CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="66,3,*"
                                          ColumnSpacing="12">
                                        <VerticalStackLayout Grid.Column="0"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                                   Style="{StaticResource TimeLeadingLabel}" />
                                        </VerticalStackLayout>

                                        <BoxView Grid.Column="1"
                                                 Color="{StaticResource ReadierAccent}"
                                                 CornerRadius="2"
                                                 WidthRequest="3"
                                                 VerticalOptions="Fill" />

                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="4"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding Title}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                            <Label Text="{Binding DestinationLabel}"
                                                   FontSize="12"
                                                   IsVisible="{Binding HasDestination}"
                                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                                            <HorizontalStackLayout Spacing="6" Margin="0,2,0,0">
                                                <Label Text="{Binding StartPrepAt, StringFormat='준비 {0:HH:mm}'}"
                                                       Style="{StaticResource BadgeText}"
                                                       BackgroundColor="{StaticResource ReadierWarning}" />
                                                <Label Text="{Binding LeaveAt, StringFormat='출발 {0:HH:mm}'}"
                                                       Style="{StaticResource BadgeText}"
                                                       BackgroundColor="{StaticResource ReadierAccent}" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </SwipeView>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <ScrollView IsVisible="{Binding IsCalendarMode}">
                <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
                    <Border Grid.Row="0" Style="{StaticResource SurfaceCard}" Padding="14,10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                            <Button Grid.Column="0"
                                    Text="◀"
                                    Style="{StaticResource TonalButton}"
                                    WidthRequest="44"
                                    Command="{Binding PreviousMonthCommand}" />
                            <Label Grid.Column="1"
                                   Text="{Binding CalendarMonthTitle}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                            <Button Grid.Column="2"
                                    Text="▶"
                                    Style="{StaticResource TonalButton}"
                                    WidthRequest="44"
                                    Command="{Binding NextMonthCommand}" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*,*,*" Padding="8,0">
                        <Label Grid.Column="0" Text="일" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="1" Text="월" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="2" Text="화" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="3" Text="수" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="4" Text="목" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="5" Text="금" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                        <Label Grid.Column="6" Text="토" HorizontalTextAlignment="Center" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                    </Grid>

                    <Border Grid.Row="2" Style="{StaticResource SurfaceCard}" Padding="8">
                        <CollectionView ItemsSource="{Binding CalendarDays}" SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Span="7" Orientation="Vertical" HorizontalItemSpacing="4" VerticalItemSpacing="4" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CalendarDayViewModel">
                                    <Border StrokeThickness="0"
                                            Padding="0"
                                            HeightRequest="44">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference page}, Path=ViewModel.SelectDateCommand}"
                                                                  CommandParameter="{Binding Date}" />
                                        </Border.GestureRecognizers>
                                        <Grid RowDefinitions="Auto,Auto" RowSpacing="3">
                                            <Label Grid.Row="0"
                                                   Text="{Binding DayLabel}"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   FontSize="13"
                                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                            <BoxView Grid.Row="1"
                                                     HeightRequest="4"
                                                     WidthRequest="4"
                                                     HorizontalOptions="Center"
                                                     CornerRadius="2"
                                                     IsVisible="{Binding HasItems}"
                                                     Color="{StaticResource ReadierAccent}" />
                                        </Grid>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsCurrentMonth}" Value="False">
                                                <Setter Property="Opacity" Value="0.45" />
                                            </DataTrigger>
                                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#E8EEFF, Dark=#2A355E}" />
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>

                    <Border Grid.Row="3" Style="{StaticResource SurfaceCard}" Padding="16,12">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding AgendaTitle}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                            <CollectionView ItemsSource="{Binding VisibleItems}" SelectionMode="None" HeightRequest="240">
                                <CollectionView.EmptyView>
                                    <Label Text="선택한 날짜에 일정이 없어요"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ScheduleListItemViewModel">
                                        <Grid ColumnDefinitions="58,*" ColumnSpacing="8">
                                            <Label Grid.Column="0"
                                                   Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </ScrollView>
        </Grid>

        <Button Text="+"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                BackgroundColor="{StaticResource ReadierAccent}"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,28"
                Command="{Binding AddCommand}" />
    </Grid>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Readier.ViewModels"
             x:Class="Readier.Views.ScheduleListPage"
             x:DataType="vm:ScheduleListViewModel"
             x:Name="page"
             Title="{Binding Title}"
             BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}">

    <Grid>
        <CollectionView ItemsSource="{Binding Groups}"
                        IsGrouped="True"
                        SelectionMode="None"
                        Margin="0,4,0,0">

            <CollectionView.EmptyView>
                <Grid Padding="40,80">
                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12">
                        <Label Text="📅"
                               FontSize="56"
                               HorizontalOptions="Center"
                               Opacity="0.5" />
                        <Label Text="아직 일정이 없어요"
                               FontSize="18"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                        <Label Text="우측 하단 + 버튼으로 첫 일정을 추가해 보세요"
                               FontSize="13"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                    </VerticalStackLayout>
                </Grid>
            </CollectionView.EmptyView>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:ScheduleGroup">
                    <Label Text="{Binding Title}"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}"
                           Padding="20,18,20,6" />
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ScheduleListItemViewModel">
                    <SwipeView Margin="14,4">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem Text="삭제"
                                           BackgroundColor="{StaticResource ReadierDanger}"
                                           Command="{Binding Source={x:Reference page}, Path=ViewModel.DeleteCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Style="{StaticResource SurfaceCard}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference page}, Path=ViewModel.EditCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="58,3,*"
                                  ColumnSpacing="14">
                                <VerticalStackLayout Grid.Column="0"
                                                     Spacing="2"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding StartTime, StringFormat='{0:HH:mm}'}"
                                           FontSize="20"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                </VerticalStackLayout>

                                <BoxView Grid.Column="1"
                                         Color="{StaticResource ReadierAccent}"
                                         CornerRadius="2"
                                         WidthRequest="3"
                                         VerticalOptions="Fill" />

                                <VerticalStackLayout Grid.Column="2"
                                                     Spacing="3"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextLight}, Dark={StaticResource ReadierTextDark}}" />
                                    <Label Text="{Binding DestinationLabel}"
                                           FontSize="12"
                                           IsVisible="{Binding HasDestination}"
                                           TextColor="{AppThemeBinding Light={StaticResource ReadierTextSubtleLight}, Dark={StaticResource ReadierTextSubtleDark}}" />
                                    <Label Text="{Binding LeaveAt, StringFormat='출발 {0:HH:mm}'}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource ReadierAccent}"
                                           Margin="0,2,0,0" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="+"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                BackgroundColor="{StaticResource ReadierAccent}"
                WidthRequest="60"
                HeightRequest="60"
                CornerRadius="30"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,20,28"
                Command="{Binding AddCommand}" />
    </Grid>
</ContentPage>

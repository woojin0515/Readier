<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Readier.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Readier.Views"
    Title="Readier"
    FlyoutBehavior="Flyout"
    BackgroundColor="{AppThemeBinding Light={StaticResource ReadierBgLight}, Dark={StaticResource ReadierBgDark}}"
    FlyoutBackgroundColor="{AppThemeBinding Light={StaticResource ReadierSurfaceLight}, Dark={StaticResource ReadierSurfaceDark}}">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="140"
              Padding="20,40,20,20"
              BackgroundColor="{StaticResource ReadierAccent}">
            <VerticalStackLayout Spacing="2" VerticalOptions="End">
                <Label Text="Readier"
                       TextColor="White"
                       FontSize="24"
                       FontAttributes="Bold" />
                <Label Text="더 이상 늦지 않게"
                       TextColor="White"
                       Opacity="0.85"
                       FontSize="13" />
            </VerticalStackLayout>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="일정"
                Route="ScheduleListPage">
        <ShellContent ContentTemplate="{DataTemplate views:ScheduleListPage}" />
    </FlyoutItem>

    <FlyoutItem Title="분석"
                Route="BehaviorAnalysisPage">
        <ShellContent ContentTemplate="{DataTemplate views:BehaviorAnalysisPage}" />
    </FlyoutItem>

    <MenuItem x:Name="SettingsMenuItem"
              Text="설정"
              Clicked="OnSettingsMenuClicked" />

</Shell>
